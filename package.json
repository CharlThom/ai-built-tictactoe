{
  "name": "tictactoe-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TicTacToe monorepo with frontend and shared utilities",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm -r build",

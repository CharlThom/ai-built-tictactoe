# Stripe API Configuration
# Copy this file to .env and fill in your actual keys

# Environment: development or production
STRIPE_ENVIRONMENT=development

# Stripe API Version (optional, defaults to 2023-10-16)
STRIPE_API_VERSION=2023-10-16

# Development/Test Keys
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_TEST_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_test_webhook_secret_here

# Production/Live Keys
# Get these from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Keep these secure and never commit to version control
STRIPE_LIVE_SECRET_KEY=sk_live_your_live_secret_key_here
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_webhook_secret_here

# Setup Instructions:
# 1. Create a Stripe account at https://stripe.com
# 2. For development:
#    - Go to https://dashboard.stripe.com/test/apikeys
#    - Copy your test keys and paste above
# 3. For production (when ready):
#    - Complete Stripe account activation
#    - Go to https://dashboard.stripe.com/apikeys
#    - Copy your live keys and paste above
# 4. For webhooks:
#    - Go to https://dashboard.stripe.com/test/webhooks (or /webhooks for live)
#    - Create endpoint and copy the signing secret